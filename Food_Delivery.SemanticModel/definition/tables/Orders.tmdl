	column Order_Time = IF(Orders[DeliveryTimeMins]>45,"Late","On Time")
		lineageTag: e61cab5f-a37a-4dc1-9248-7edfc25206f5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Order_Months = FORMAT(Orders[OrderDate],"mmmm yyyy")
		lineageTag: cfda4c5c-d78a-46e7-ae6b-d7cbc397df18
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

