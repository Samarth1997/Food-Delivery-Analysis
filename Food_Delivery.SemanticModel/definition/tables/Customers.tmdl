table Customers
	lineageTag: 0a4c185a-bdca-4289-990e-8dd6b807fa74

	measure customer_return = CALCULATE(COUNTROWS(Customers),Customers[New_Or_Return]="Repeat")
		formatString: 0
		lineageTag: 67ff8dec-93f1-4cd8-aeed-eb9debad4725

	column CustomerID
