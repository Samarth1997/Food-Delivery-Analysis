		summarizeBy: none
		sourceColumn: CustomerName

		annotation SummarizationSetBy = Automatic

	column City
		dataType: string
		lineageTag: 3400840a-2832-483f-a5b8-d31147d3bbe4
		summarizeBy: none
		sourceColumn: City

		annotation SummarizationSetBy = Automatic

	column SignupDate
		dataType: dateTime
		formatString: Long Date
		lineageTag: e912be53-e204-4483-9d20-f63dec049877
		summarizeBy: none
		sourceColumn: SignupDate

		variation Variation
			isDefault
			relationship: a0bde30f-f82b-44de-a752-3fdb8f84cb23
			defaultHierarchy: LocalDateTable_6b60773e-09fb-406f-806e-be8161ad648c.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column CustomerType
		dataType: string
		lineageTag: a260ae48-f374-4b31-880b-737fe8eb8eb9
		summarizeBy: none
		sourceColumn: CustomerType

		annotation SummarizationSetBy = Automatic

	column 'Filter City' =
			VAR val = Customers[City]
			VAR wordCount = LEN(val) - LEN(SUBSTITUTE(val, " ", "")) + 1
			RETURN
			IF(
			
			ISBLANK(val) || wordCount > 4 || LEN(val) > 50,
			BLANK(),
			val
			)
		lineageTag: 24225638-b18b-44bc-9a51-b577447be404
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column New_Or_Return = IF(Customers[CustomerType]=="New","New","Repeat")
		lineageTag: a9cbc640-002a-488a-9771-05ae02ada796
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

